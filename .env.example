# Local development database connection.
# Vercel may provide POSTGRES_URL automatically; DATABASE_URL also works.
DATABASE_URL=postgres://user:password@localhost:5432/restaurant_order

# Use false for local Postgres without SSL. Leave unset/true for hosted providers.
PGSSL=false

# Local server port.
PORT=3000

# Required for lock-screen/background Web Push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
